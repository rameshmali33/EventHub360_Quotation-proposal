{
  "name": "eventhub360",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "description": "EventHub 360 quotation and proposal management platform",
  "scripts": {
